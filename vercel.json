{
  "version": 2,
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && tsc -b && vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
